# ---- OpenAI ----
OPENAI_API_KEY=            # OpenAI API key (required)
OPENAI_CHAT_MODEL=gpt-4o-mini
OPENAI_EMBED_MODEL=text-embedding-3-small

# ---- LangSmith (tracing) ----
LANGSMITH_TRACING=true
LANGSMITH_API_KEY=         # LangSmith API key (lsv2_...)
LANGSMITH_PROJECT=reel-agent

# ---- LightRAG Postgres (AGE + pgvector; self-hosted) ----
RAG_PG_HOST=localhost
RAG_PG_PORT=55432
RAG_PG_USER=lightrag
RAG_PG_PASSWORD=please-change-me
RAG_PG_DATABASE=lightrag
RAG_PG_WORKSPACE=reel
LIGHTRAG_WORKING_DIR=/data/lightrag

# ---- Ingestion ----
SUBSET_SIZE=503            # consistent deployed subset; raise toward 1000 when quota allows
INGEST_CONCURRENCY=4
TMDB_API_ACCESS_TOKEN=     # TMDB v4 bearer token (poster enrichment)
TMDB_API_KEY=              # optional; access token is preferred

# ---- Supabase (auth + chat + checkpoints + UI projection) ----
SUPABASE_URL=              # https://<project-ref>.supabase.co
SUPABASE_JWT_AUD=authenticated
SUPABASE_DB_URL=           # postgresql://... (LangGraph + projection reads/writes)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
NEXT_PUBLIC_API_URL=http://localhost:8000

# ---- Backend ----
# Local: APP_ENV=dev and CORS_ALLOW_ORIGINS=http://localhost:3000
# Prod (EC2): APP_ENV=prod and only your Vercel origin(s) — never *
CORS_ALLOW_ORIGINS=https://reel-frontend-six.vercel.app
APP_ENV=prod

# ---- LLM safety ----
LLM_TIMEOUT_SECONDS=30
LLM_MAX_TOKENS=1024
