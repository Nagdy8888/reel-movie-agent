// Reel sample movie knowledge graph seed.
// Schema: (:Movie {title, released, tagline}), (:Person {name, born}),
//         (:Person)-[:ACTED_IN]->(:Movie), (:Person)-[:DIRECTED]->(:Movie).
// This is a single CREATE statement so it can be executed in one transaction
// by the ingestion loader (apps/agents/src/ingestion/load_graph.py).
// Constraints are created separately by the loader before this runs.

CREATE (TheMatrix:Movie {title: 'The Matrix', released: 1999, tagline: 'Welcome to the Real World'})
CREATE (MatrixReloaded:Movie {title: 'The Matrix Reloaded', released: 2003, tagline: 'Free your mind'})
CREATE (ForrestGump:Movie {title: 'Forrest Gump', released: 1994, tagline: 'Life is like a box of chocolates...'})
CREATE (CastAway:Movie {title: 'Cast Away', released: 2000, tagline: 'At the edge of the world, his journey begins'})
CREATE (Apollo13:Movie {title: 'Apollo 13', released: 1995, tagline: 'Houston, we have a problem'})
CREATE (SavingPrivateRyan:Movie {title: 'Saving Private Ryan', released: 1998, tagline: 'The mission is a man'})
CREATE (CatchMeIfYouCan:Movie {title: 'Catch Me If You Can', released: 2002, tagline: 'The true story of a real fake'})
CREATE (Titanic:Movie {title: 'Titanic', released: 1997, tagline: 'Nothing on Earth could come between them'})
CREATE (Inception:Movie {title: 'Inception', released: 2010, tagline: 'Your mind is the scene of the crime'})
CREATE (Interstellar:Movie {title: 'Interstellar', released: 2014, tagline: 'Mankind was born on Earth. It was never meant to die here.'})
CREATE (TheDarkKnight:Movie {title: 'The Dark Knight', released: 2008, tagline: 'Why So Serious?'})
CREATE (BatmanBegins:Movie {title: 'Batman Begins', released: 2005, tagline: 'It takes a legend to end one'})
CREATE (ThePrestige:Movie {title: 'The Prestige', released: 2006, tagline: 'Are you watching closely?'})
CREATE (PulpFiction:Movie {title: 'Pulp Fiction', released: 1994, tagline: 'Just because you are a character does not mean you have character'})
CREATE (DjangoUnchained:Movie {title: 'Django Unchained', released: 2012, tagline: 'Life, liberty and the pursuit of vengeance'})
CREATE (WolfOfWallStreet:Movie {title: 'The Wolf of Wall Street', released: 2013, tagline: 'More is never enough'})
CREATE (TheDeparted:Movie {title: 'The Departed', released: 2006, tagline: 'Lies. Betrayal. Sacrifice. How far will you take it?'})
CREATE (Gladiator:Movie {title: 'Gladiator', released: 2000, tagline: 'A hero will rise'})
CREATE (TheMartian:Movie {title: 'The Martian', released: 2015, tagline: 'Bring him home'})
CREATE (FightClub:Movie {title: 'Fight Club', released: 1999, tagline: 'Mischief. Mayhem. Soap.'})
CREATE (Se7en:Movie {title: 'Se7en', released: 1995, tagline: 'Seven deadly sins. Seven ways to die.'})
CREATE (Shawshank:Movie {title: 'The Shawshank Redemption', released: 1994, tagline: 'Fear can hold you prisoner. Hope can set you free.'})

