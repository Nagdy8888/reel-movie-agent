# syntax=docker/dockerfile:1
FROM pgvector/pgvector:pg16-bookworm AS build

RUN apt-get update \
  && apt-get install -y --no-install-recommends \
    bison \
    build-essential \
    ca-certificates \
    flex \
    git \
    postgresql-server-dev-16 \
  && git clone --depth 1 --branch release/PG16/1.5.0 \
    https://github.com/apache/age.git /usr/src/age \
  && make -C /usr/src/age \
  && make -C /usr/src/age install

FROM pgvector/pgvector:pg16-bookworm

COPY --from=build /usr/lib/postgresql/16/lib/age.so /usr/lib/postgresql/16/lib/
COPY --from=build /usr/share/postgresql/16/extension/age* \
  /usr/share/postgresql/16/extension/

RUN printf '%s\n' \
  'CREATE EXTENSION IF NOT EXISTS vector;' \
  'CREATE EXTENSION IF NOT EXISTS age CASCADE;' \
  > /docker-entrypoint-initdb.d/00-create-extensions.sql

CMD ["postgres", "-c", "shared_preload_libraries=age"]
